#!/usr/bin/env bash
set -uo pipefail
export LC_ALL=C

readonly TARGET_NAME="nvim-target"
readonly DEFAULT_TARGET_NAME="default-nvim-target"
readonly REMOTE_OK="talk2text-ok"

readonly NOTIFY_CMD=${TALK2TEXT_NVIM_NOTIFY_CMD-'notify-send -a talk2text -u normal -t 5000 Talk2text "$@"'}
readonly CLIENT_CMD=${TALK2TEXT_NVIM_CLIENT_CMD-'nvim "$@"'}
readonly TERMINAL_CMD=${TALK2TEXT_NVIM_TERMINAL_CMD-}
readonly FOCUS_CMD=${TALK2TEXT_NVIM_FOCUS_CMD-}

RUNTIME_DIR=
TRANSCRIPT_PATH=

# Outputs set by read_target_locked for its caller.
TARGET_EXISTS=0
TARGET_VALUE=
# File descriptor held while the runtime directory is locked.
RUNTIME_LOCK_FD=
# Escaped path bytes produced by encode_lua_bytes.
LUA_BYTES=

fail() {
  printf 'talk2text-nvim: %s\n' "$*" >&2
  return 1
}

path_exists() {
  local path="$1"
  # The existence test follows symlinks, so it fails for a dangling symlink.
  [[ -e $path || -L $path ]]
}

run_hook() {
  local code="$1"
  shift
  sh -c "$code" talk2text-nvim-hook "$@"
}

notify() {
  [[ -n $NOTIFY_CMD ]] || return 0
  run_hook "$NOTIFY_CMD" "$@" || true
}

focus_default_editor() {
  [[ -n $FOCUS_CMD ]] || return 0
  run_hook "$FOCUS_CMD" || true
}

lock_runtime() {
  if ! exec {RUNTIME_LOCK_FD}<"$RUNTIME_DIR"; then
    fail "cannot open runtime directory for locking"
    return 1
  fi
  if ! flock -x "$RUNTIME_LOCK_FD"; then
    exec {RUNTIME_LOCK_FD}<&-
    RUNTIME_LOCK_FD=
    fail "cannot lock runtime directory"
    return 1
  fi
}

unlock_runtime() {
  if [[ -n $RUNTIME_LOCK_FD ]]; then
    flock -u "$RUNTIME_LOCK_FD" || true
    exec {RUNTIME_LOCK_FD}<&-
    RUNTIME_LOCK_FD=
  fi
}

read_target_locked() {
  local target_path="$1"
  TARGET_EXISTS=0
  TARGET_VALUE=

  path_exists "$target_path" || return 0

  TARGET_EXISTS=1
  IFS= read -r TARGET_VALUE <"$target_path" 2>/dev/null || true
  TARGET_VALUE=${TARGET_VALUE#"${TARGET_VALUE%%[![:space:]]*}"}
  TARGET_VALUE=${TARGET_VALUE%"${TARGET_VALUE##*[![:space:]]}"}
}

read_target() {
  local target_path="$1"
  lock_runtime || return 1
  read_target_locked "$target_path"
  unlock_runtime
}

delete_target_if_unchanged() {
  local target_path="$1"
  local expected="$2"
  lock_runtime || return 1
  read_target_locked "$target_path"
  if ((TARGET_EXISTS)) && [[ $TARGET_VALUE == "$expected" ]]; then
    if ! rm -f -- "$target_path"; then
      unlock_runtime
      fail "cannot remove unusable target: $target_path"
      return 1
    fi
  fi
  unlock_runtime
}

encode_lua_bytes() {
  local input="$1"
  local output=
  local byte escaped i
  for ((i = 0; i < ${#input}; i++)); do
    printf -v byte '%d' "'${input:i:1}"
    printf -v escaped '\\%03d' "$byte"
    output+="$escaped"
  done
  LUA_BYTES="$output"
}

probe_server() {
  local socket="$1"
  run_hook "$CLIENT_CMD" --server "$socket" --remote-expr 1 2>/dev/null
}

load_in_server() {
  local socket="$1"
  encode_lua_bytes "$TRANSCRIPT_PATH"
  local expression="luaeval('require(\"talk2text\")._remote_load(\"$LUA_BYTES\")')"
  local response
  response=$(run_hook "$CLIENT_CMD" --server "$socket" --remote-expr "$expression") || return 1
  [[ $response == "$REMOTE_OK" ]]
}

# Returns 0 when the transcript was delivered, 1 when the target is unavailable
# and the caller should try another target, or 2 when delivery must stop.
try_target() {
  local target_path="$RUNTIME_DIR/$1"

  read_target "$target_path" || return 2
  if ((!TARGET_EXISTS)); then
    return 1
  fi

  local observed="$TARGET_VALUE"
  if [[ -z $observed ]] || ! probe_server "$observed"; then
    delete_target_if_unchanged "$target_path" "$observed" || return 2
    return 1
  fi

  if ! load_in_server "$observed"; then
    fail "Neovim target was reachable but transcript loading failed"
    return 2
  fi

  return 0
}

start_default_editor() {
  if [[ -z $TERMINAL_CMD ]]; then
    fail "TALK2TEXT_NVIM_TERMINAL_CMD is required to start a default editor"
    return 1
  fi

  encode_lua_bytes "$TRANSCRIPT_PATH"
  local startup="lua require(\"talk2text\")._default_start(\"$LUA_BYTES\")"
  run_hook "$TERMINAL_CMD" -c "$startup"
}

handle_text() {
  if [[ -z $CLIENT_CMD ]]; then
    fail "TALK2TEXT_NVIM_CLIENT_CMD is required for text delivery"
    return 1
  fi
  if [[ ! -f $TRANSCRIPT_PATH || ! -r $TRANSCRIPT_PATH ]]; then
    fail "text transcript must be a readable regular file"
    return 1
  fi

  try_target "$TARGET_NAME"
  case $? in
    0) return 0 ;;
    2) return 1 ;;
  esac

  try_target "$DEFAULT_TARGET_NAME"
  case $? in
    0)
      focus_default_editor
      return 0
      ;;
    2) return 1 ;;
  esac

  start_default_editor
}

remove_transcript() {
  if ! rm -f -- "$TRANSCRIPT_PATH"; then
    fail "cannot remove transcript"
    return 1
  fi
}

handle_blank() {
  remove_transcript
  notify "Blank transcript"
}

handle_short() {
  remove_transcript
  local target_path="$RUNTIME_DIR/$TARGET_NAME"
  lock_runtime || return 1
  if ! rm -f -- "$target_path"; then
    unlock_runtime
    fail "cannot reset target to default"
    return 1
  fi
  unlock_runtime
  notify "Target reset to default"
}

set_runtime_dir() {
  local transcript_dir="${TRANSCRIPT_PATH%/*}"
  if [[ ${transcript_dir##*/} != transcripts ]]; then
    fail "transcript path must be directly under a transcripts directory"
    return 1
  fi

  RUNTIME_DIR="${transcript_dir%/*}"
  if [[ -z $RUNTIME_DIR || $RUNTIME_DIR =~ ^/+$ ]]; then
    fail "runtime directory must not be the filesystem root"
    return 1
  fi
  if [[ ! -d $RUNTIME_DIR ]]; then
    fail "runtime directory is unavailable"
    return 1
  fi
}

main() {
  if (($# != 2)); then
    fail "usage: talk2text-nvim <text|blank|short> <path>"
    return 1
  fi

  local kind="$1"
  TRANSCRIPT_PATH="$2"
  if [[ $TRANSCRIPT_PATH != /* || $TRANSCRIPT_PATH == */ ]]; then
    fail "transcript path must be an absolute file path"
    return 1
  fi

  set_runtime_dir || return 1
  case "$kind" in
    text) handle_text ;;
    blank) handle_blank ;;
    short) handle_short ;;
    *)
      fail "unknown transcript kind: $kind"
      return 1
      ;;
  esac
}

main "$@" >/dev/null
